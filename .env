# Optional environment variables for Overleaf
# Copy to .env and customize as needed

# Site Configuration
OVERLEAF_SITE_URL=https://overleaf.jvsanten.com
OVERLEAF_NAV_TITLE=Overleaf
OVERLEAF_ADMIN_EMAIL=admin@jvsanten.com

# Behind Proxy (for Coolify/Traefik) - set to true when deploying to Coolify, false for local testing
OVERLEAF_BEHIND_PROXY=true
